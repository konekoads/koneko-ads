---
import { METRICS_SECTION, METRICS } from '@content/metrics'
import SectionLabel from './ui/SectionLabel.astro'
---

<section
  id="resultados"
  class="bg-koneko-bg py-section-mobile lg:py-section-desktop"
  aria-labelledby="metrics-heading"
>
  <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-16">
      <SectionLabel text={METRICS_SECTION.eyebrow} />
      <h2
        id="metrics-heading"
        class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-koneko-text mt-4 max-w-3xl mx-auto"
      >
        {METRICS_SECTION.headline}
      </h2>
    </div>

    <!-- Métricas -->
    <div class="grid sm:grid-cols-3 gap-8 lg:gap-12">
      {METRICS.map(metric => (
        <div class="text-center group">
          <div class="relative inline-block">
            <p
              class="font-display font-bold text-6xl lg:text-7xl text-koneko-primary group-hover:text-koneko-primary-light transition-colors duration-300"
              aria-label={`${metric.value} — ${metric.label}`}
            >
              {metric.value}
            </p>
            <!-- Glow sutil bajo el número -->
            <div
              class="absolute inset-x-0 bottom-0 h-1/2 bg-koneko-primary/20 blur-2xl -z-10"
              aria-hidden="true"
            ></div>
          </div>
          <p class="mt-3 text-xs font-semibold tracking-widest uppercase text-koneko-text-muted">
            {metric.label}
          </p>
          <!-- Separador decorativo -->
          <div class="mt-4 w-8 h-px bg-koneko-primary/40 mx-auto" aria-hidden="true"></div>
        </div>
      ))}
    </div>
  </div>
</section>
