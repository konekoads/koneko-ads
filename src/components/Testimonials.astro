---
import { TESTIMONIALS_SECTION, TESTIMONIALS } from '@content/testimonials'
import SectionLabel from './ui/SectionLabel.astro'
---

<section
  id="testimonios"
  class="bg-koneko-bg-alt py-section-mobile lg:py-section-desktop"
  aria-labelledby="testimonials-heading"
>
  <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-16">
      <SectionLabel text={TESTIMONIALS_SECTION.eyebrow} />
      <h2
        id="testimonials-heading"
        class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-koneko-text mt-4"
      >
        {TESTIMONIALS_SECTION.headline}
      </h2>
    </div>

    <!-- Lista de testimonios centrada -->
    <div
      class="flex flex-col gap-6 max-w-[720px] mx-auto"
      role="list"
      aria-label="Testimonios de clientes"
    >
      {TESTIMONIALS.map(t => (
        <article
          role="listitem"
          class="relative bg-koneko-card border border-koneko-border rounded-2xl p-6 sm:p-8"
        >
          <!-- Badge Google Reviews — esquina superior derecha -->
          <div
            class="absolute top-5 right-5 flex items-center gap-1.5 text-xs text-koneko-text-muted"
            aria-label="Reseña verificada"
          >
            <!-- Google "G" SVG inline -->
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span>Google Reviews</span>
          </div>

          <!-- Estrellas -->
          <div
            class="flex gap-1 mb-4"
            role="img"
            aria-label={`${t.stars} de 5 estrellas`}
          >
            {Array.from({ length: t.stars }).map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#7C3AED" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>

          <!-- Texto del testimonio -->
          <blockquote>
            <p class="text-koneko-text leading-relaxed text-base sm:text-lg mb-6">
              "{t.text}"
            </p>
          </blockquote>

          <!-- Autor -->
          <div class="flex items-center gap-3">
            <!-- Avatar con iniciales -->
            <div
              class="w-10 h-10 rounded-full bg-koneko-primary/20 border border-koneko-primary/40 flex items-center justify-center flex-shrink-0"
              aria-hidden="true"
            >
              <span class="text-xs font-bold text-koneko-primary-light">
                {t.initials}
              </span>
            </div>
            <div>
              <p class="font-semibold text-sm text-koneko-text">{t.name}</p>
              <p class="text-xs text-koneko-text-muted">{t.role}</p>
            </div>
          </div>

          <!-- Nota contextual -->
          <p class="mt-4 pt-4 border-t border-koneko-border text-xs text-koneko-text-muted italic">
            {t.context}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
